{
  "branch": "main",
  "ruleset_id": 18506136,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "require_linear_history": true,
  "require_signed_commits": true,
  "strict_required_status_checks": true,
  "required_pull_request": {
    "required_approving_review_count": 0,
    "dismiss_stale_reviews": true,
    "require_code_owner_review": false,
    "require_review_thread_resolution": true,
    "allowed_merge_methods": ["squash"]
  },
  "required_status_checks": [
    "ci-gate"
  ],
  "repository_settings": {
    "merge_methods": ["squash"],
    "squash_commit_title": "pull request title",
    "delete_branch_on_merge": true,
    "allow_update_branch": true,
    "wiki_enabled": false,
    "projects_enabled": false
  },
  "notes": [
    "This file records the live repository ruleset and merge settings.",
    "The solo-maintainer repository requires a pull request and resolved review threads but no impossible self-approval.",
    "Administrators retain an audited emergency bypass; normal merges wait for ci-gate."
  ]
}
